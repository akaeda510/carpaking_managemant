<%= render layout: 'parking_managers/shared/auth_card', locals: { title: "新しいメールアドレスの登録" } do %>

  <div class="mb-6">
    <p class="text-sm text-gray-600">
    本人確認が完了しました。新しいメールアドレスを入力してください。
    </p>
  </div>

  <%= form_with(model: @email_change, url: parking_managers_email_change_path(@email_change.token), scope: :email_change, method: :patch, class: "space-y-6") do |f| %>

    <div>
      <%= f.label :new_email, "新しいメールアドレス" %>
      <%= f.email_field :new_email, 
        value: "",
        required: true, 
        class: "auth-input",
        placeholder: "新しいメールアドレスを入力" %>
      <p class="mt-1 text-xs text-gray-500">※このアドレスに完了通知が届きます</p>
    </div>

    <div class="field">
  <%= f.label :new_email_confirmation, "新しいメールアドレス（確認用）" %>
  <%= f.email_field :new_email_confirmation, required: true, class: "auth-input" %>
    </div>

    <%= f.submit "メールアドレスを更新する", class: "auth-submit" %>
  <% end %>

  <div class="mt-8 pt-4 border-t border-gray-100 text-center">
    <%= back_link_to "キャンセル", my_dashboard_root_path(@parking_manager) %>
  </div>

<% end %>
