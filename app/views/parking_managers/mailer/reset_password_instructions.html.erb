<%# app/views/parking_managers/mailer/reset_password_instructions.html.erb %>

<div style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333; line-height: 1.6; max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #f0f0f0; rounded: 8px;">
  <div style="text-align: center; margin-bottom: 30px;">
    <h2 style="color: #1a202c; font-size: 24px; font-weight: 800;">パスワード再設定のご案内</h2>
  </div>

  <p style="font-size: 16px;">こんにちは、<%= @resource.email %> 様</p>

  <p style="font-size: 14px; color: #4a5568;">
    お客様のアカウントでパスワード再設定のリクエストを受け付けました。<br>
    お心当たりがある場合は、以下のボタンをクリックして新しいパスワードを設定してください。
  </p>

  <div style="text-align: center; margin: 40px 0;">
    <%= link_to 'パスワードを再設定する', 
        edit_password_url(@resource, reset_password_token: @token), 
        style: "background-color: #2563eb; color: white; padding: 14px 28px; text-decoration: none; border-radius: 8px; font-weight: bold; display: inline-block; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);" %>
  </div>

  <div style="background-color: #f7fafc; padding: 20px; border-radius: 8px; margin-top: 30px;">
    <p style="font-size: 12px; color: #718096; margin: 0;">
      ※このメールに心当たりがない場合は、このまま破棄してください。第三者がメールアドレスを誤入力した可能性があります。<br>
      ※上記のボタンをクリックして新しいパスワードを作成するまで、現在のパスワードが変更されることはありません。
    </p>
  </div>

  <hr style="border: 0; border-top: 1px solid #edf2f7; margin: 30px 0;">

  <p style="text-align: center; font-size: 12px; color: #a0aec0;">
    &copy; <%= Time.current.year %> tukigime-parking.com<br>
    本メールは送信専用です。
  </p>
</div>
