<%= render layout: 'parking_managers/shared/auth_card', locals: { title: "ログイン" } do %>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>

    <div class="field">
      <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1">
        <%= f.email_field :email, 
          autofocus: true, 
          autocomplete: "email",
          placeholder: "メールアドレスを入力",
          class: "auth-input" %>
      </div>
    </div>

    <div class="field">
      <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1">
        <%= f.password_field :password, 
          autocomplete: "current-password",
          placeholder: "パスワードを入力",
          class: "auth-input" %>
      </div>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="field flex items-center justify-start pt-1">
        <%= f.check_box :remember_me, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
        <%= f.label :remember_me, class: "ml-2 block text-sm text-gray-900" %>
      </div>
    <% end %>

    <div class="actions mt-6"> <%= f.submit "ログイン", class: "auth-submit" %>
    </div>

    <div class="text-sm pt-4"> 
      <div class="flex flex-col items-end space-y-2"> 
        <%= render "parking_managers/shared/links" %>
      </div>
    </div>

  <% end %>
<% end %>
