<%= render layout: 'parking_managers/shared/auth_card', locals: { title: "パスワードを設定" } do %>
  <% if parking_manager_signed_in? %>
    <p class="text-sm text-gray-600 mb-6 bg-green-50 p-3 rounded border border-green-200">
      本人確認が完了しました。新しいパスワードを入力してください。
    </p>
  <% else %>
    <p class="text-sm text-gray-600 mb-6">
      メールリンクを確認しました。新しいパスワードを設定して再開しましょう。
    </p>
  <% end %>

  <%= render "form_fields", resource: resource, resource_name: resource_name %>

<% end %>
