<div class="flex min-h-[50vh] flex-col items-center justify-center px-4 py-12 sm:px-6 lg:px-8">
  <div class="w-full max-w-md space-y-8 text-center bg-white p-8 rounded-xl shadow-sm border border-gray-100">
    
    <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-green-100">
      <svg class="h-12 w-12 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>

    <div class="space-y-4">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900">
        端末の登録が完了しました
      </h2>
      <p class="text-sm text-gray-600">
        この端末「<span class="font-semibold text-gray-900"><%= @device.name %></span>」を信頼済みとして登録しました。
      </p>
    </div>

    <div class="pt-4">
      <p class="text-sm text-gray-500 mb-6">
        <span id="countdown" class="font-bold text-lg text-blue-600">5</span> 秒後に自動で画面が移動します...
      </p>

      <%= link_to my_dashboard_root_path,
          class: "inline-flex w-full justify-center rounded-md bg-blue-600 px-3 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-colors" do %>
        自動で移動しない場合はこちらをクリック
      <% end %>
    </div>
  </div>
</div>

<script>
  (function() {
    let timeLeft = 5;
    const countdownElement = document.getElementById('countdown');

    const timer = setInterval(() => {
      timeLeft -= 1;
      if (countdownElement) countdownElement.textContent = timeLeft;

      if (timeLeft <= 0) {
        clearInterval(timer);
        window.location.href = "<%= my_dashboard_root_path(verified_token: @device.device_token) %>";
      }
    }, 1000);
  })();
</script>
