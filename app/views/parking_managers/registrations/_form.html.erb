<%= form_with model: resource, scope: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" } do |f| %>

  <section class="border border-gray-200 p-6 rounded-lg bg-white shadow-sm">
    <h3 class="text-xl font-semibold text-indigo-600 mb-6 border-b pb-2">基本情報・認証情報</h3>

    <div class="space-y-6">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name, '氏名(姓)', class: "auth-label" %>
          <%= f.text_field :first_name, autofocus: true, autocomplete: "family-name", class: "auth-input" %>
        </div>
        <div>
          <%= f.label :last_name, '氏名(名)', class: "auth-label" %>
          <%= f.text_field :last_name, autocomplete: "given-name", class: "auth-input" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :password, class: "auth-label" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "auth-input" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-500 mt-1"><%= @minimum_password_length %>文字以上</p>
          <% end %>
        </div>
        <div>
          <%= f.label :password_confirmation, 'パスワード（確認用）', class: "auth-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input" %>
        </div>
      </div>

      <div class="pt-4 border-t border-gray-100">
        <label class="auth-label">携帯電話番号 (必須)</label>
        <div class="flex items-center space-x-2">
          <input type="text" name="tel1" class="auth-input text-center w-20" maxlength="3" placeholder="090">
          <span class="text-gray-400">-</span>
          <input type="text" name="tel2" class="auth-input text-center w-24" maxlength="4" placeholder="1234">
          <span class="text-gray-400">-</span>
          <input type="text" name="tel3" class="auth-input text-center w-24" maxlength="4" placeholder="5678">
        </div>
      </div>
      <div class="pt-4 border-t border-gray-100">
        <details class="group">
          <summary class="flex items-center font-medium text-sm text-indigo-600 cursor-pointer list-none hover:text-indigo-800 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            <span>別の連絡先電話番号を追加する (任意)</span>
          </summary>

          <div class="mt-4 pl-5">
            <%= f.label :contact_number, '連絡先電話番号', class: "auth-label" %>
            <div class="flex items-center">
              <%= f.text_field :contact_number,
                placeholder: "0312345678 (ハイフンなし)",
                maxlength: 11,
                class: "auth-input w-full md:w-1/2" %>
            </div>
            <p class="text-xs text-gray-500 mt-2">
            固定電話や予備の番号がある場合に入力してください。
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="border border-gray-200 p-6 rounded-lg bg-white shadow-sm">

    <h3 class="text-xl font-semibold text-indigo-600 mb-6 border-b pb-2">住所情報</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :prefecture, '都道府県', class: "auth-label" %>
        <%= f.text_field :prefecture, class: "auth-input" %>
      </div>
      <div>
        <%= f.label :city, '市区町村', class: "auth-label" %>
        <%= f.text_field :city, class: "auth-input" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :street_address, '丁目番地号', class: "auth-label" %>
        <%= f.text_field :street_address, class: "auth-input" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :building, '建物名・部屋番号等 (任意)', class: "auth-label" %>
        <%= f.text_field :building, class: "auth-input" %>
      </div>
    </div>
  </section>

  <div class="actions pt-6">
    <%= f.submit "アカウントを作成", class: "auth-submit py-3 text-lg" %>
  </div>
<% end %>
