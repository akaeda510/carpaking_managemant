<div class="min-h-screen bg-gray-50 flex flex-col items-center py-12 sm:px-6 lg:px-8">
  <div class="max-w-4xl w-full bg-white shadow-xl rounded-lg p-8">

    <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-8">
      管理者アカウント編集
    </h2>

    <% if @parking_manager.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6">
        <p class="font-bold"><%= @parking_manager.errors.count %>件のエ
        ラーがあります:</p>
        <ul>
          <% @parking_manager.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>

      <section class="border border-gray-200 p-6 rounded-lg bg-white">
        <h3 class="text-xl font-semibold text-indigo-600 mb-4 border-b pb-2">基本情報</h3>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

          <div>
            <%= f.label :first_name, '姓氏 (First Name)', class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", 
              class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :last_name, '名前 (Last Name)', class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :last_name, autocomplete: "family-name", 
              class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :phone_number, '携帯電話番号 (記号 -なし 必須)', class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :phone_number, autocomplete: "tel-national", 
              class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", 
              maxlength: 11, placeholder: "09012345678" %>
          </div>

          <div>
            <%= f.label :contact_number, '電話番号 (記号 -なし 任意)', class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :contact_number, autocomplete: "tel-other", 
              class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", 
              maxlength: 11, placeholder: "0312345678" %>
          </div>

        </div>
      </section>

      <section class="border border-gray-200 p-6 rounded-lg bg-white">
        <h3 class="text-xl font-semibold text-indigo-600 mb-4 border-b pb-2">住所</h3>

        <div class="grid grid-cols-1 gap-6">

          <div>
            <%= f.label :prefecture, '都道府県', class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :prefecture, autocomplete: "address-level1", 
              class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :city, '市区町村', class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :city, autocomplete: "address-level2", 
              class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :street_address, '丁目番地号', class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :street_address, autocomplete: "address-line1", 
              class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :building, '建物名・部屋番号等 (任意)', class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :building, autocomplete: "address-line2", 
              class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>

        </div>
      </section>

      <div class="actions pt-4">
        <%= f.submit "アカウント情報を更新", 
          class: "auth-submit" %>
      </div>
    <% end %>

    <div class="mt-6 flex justify-center">
     <%= back_link_to "プロフィールに戻る", profile_path %>
    </div>
  </div>
</div>
