<div class="bg-white shadow rounded-lg p-6 border-t-4 border-indigo-500">
  <h2 class="text-lg font-semibold text-gray-800 mb-6 border-b pb-2 flex items-center">
    <svg class="w-5 h-5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
    契約者プロフィール
  </h2>

  <div class="space-y-4">
    <div>
      <label class="block text-xs font-bold text-gray-400 uppercase">電話番号(メイン)</label>
      <p class="text-gray-900"><%= @contractor.phone_number %></p>
    </div>

    <% if @contractor.contact_number.present? %>
      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase">連絡先電話番号</label>
        <p class="text-gray-900"><%= @contractor.contact_number %></p>
      </div>
    <% end %>

    <div>
      <label class="block text-xs font-bold text-gray-400 uppercase">住所</label>
      <p class="text-gray-900">
      <%= @contractor.address %>      
      </p>
    </div>

    <% if @contractor.notes.present? %>
      <div class="mt-6 pt-6 border-t border-gray-100">
        <label class="block text-xs font-bold text-gray-400 uppercase mb-2">備考・メモ</label>
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4">
          <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= @contractor.notes %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>
