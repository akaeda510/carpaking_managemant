<div class="bg-white shadow rounded-lg overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
    <h2 class="font-semibold text-gray-800 text-lg">契約者一覧</h2>
    <span class="bg-indigo-100 text-indigo-700 text-xs font-bold px-3 py-1 rounded-full">
      計 <%= contractors.count %> 名
    </span>
  </div>
  
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">氏名</th>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">連絡先</th>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">契約中の駐車場</th>
          <th class="px-6 py-3 text-center text-xs font-bold text-gray-400 uppercase tracking-wider">アクション</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200 text-sm">
        <% if contractors.any? %>
          <% contractors.each do |contractor| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <div class="text-gray-900 font-medium">
                  <%= contractor.full_name %>               
                </div>
              </td>
              <td class="px-6 py-4 text-gray-600">
                <%= contractor.phone_number %>
              </td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap gap-1">
                  <% contractor.parking_lots.distinct.each do |lot| %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                      <%= lot.name %>
                    </span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 text-center">
                <%= link_to '詳細', [:admin, contractor], class: "text-indigo-600 hover:text-indigo-900 font-semibold" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="px-6 py-12 text-center text-gray-400 italic">
              契約者はまだ登録されていません。
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
