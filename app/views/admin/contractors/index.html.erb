<div class="container mx-auto px-4 py-8">
  <div class="mb-4">
    <%= link_to admin_parking_managers_path, class: "inline-flex items-center text-sm font-medium text-gray-500 hover:text-blue-600 transition-colors group" do %>
      <svg class="w-5 h-5 mr-1 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      管理者一覧へ戻る
    <% end %>
  </div>
  <h1 class="text-2xl font-bold mb-6 text-gray-800">契約者一覧</h1>
  <%= render 'contractor_search' %>
  <%= render 'contractor_list', contractors: @contractors %>
</div>
