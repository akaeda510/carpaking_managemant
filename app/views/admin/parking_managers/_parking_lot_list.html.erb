<div class="bg-white shadow rounded-lg p-6 border-t-4 border-blue-500">
  <h2 class="text-lg font-semibold text-gray-800 mb-6 border-b pb-2 flex items-center">
    <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
    基本情報
  </h2>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">駐車場名</th>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">所在地</th>
          <th class="px-6 py-3 text-right text-xs font-bold text-gray-400 uppercase tracking-wider">収容台数</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200 text-sm">
        <% if @parking_lots.any? %>
          <% @parking_lots.each do |lot| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4 font-medium text-gray-900"><%= lot.name %></td>
              <td class="px-6 py-4 text-gray-600"><%= lot.address %></td>
              <td class="px-6 py-4 text-right text-gray-900"><%= lot.total_spaces %>台</td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="3" class="px-6 py-12 text-center text-gray-400">担当している駐車場は現在ありません。</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
