<div class="space-y-5">
  <div class="bg-white shadow rounded-lg p-6 border-t-4 border-blue-500">
    <h2 class="text-lg font-semibold text-gray-800 mb-6 border-b pb-2 flex items-center">
      <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
      基本情報
    </h2>
    <div>
      <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider">氏名</label>
      <p class="text-gray-900 font-medium text-lg"><%= @parking_manager.full_name %></p>
    </div>

    <div>
      <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider">メールアドレス</label>
      <p class="text-gray-900 break-all"><%= @parking_manager.email %></p>
    </div>

    <div>
      <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider">電話番号 (メイン)</label>
      <p class="text-gray-900"><%= @parking_manager.phone_number %></p>
    </div>

    <% if @parking_manager.contact_number.present? %>
      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider">連絡先電話番号</label>
        <p class="text-gray-900"><%= @parking_manager.contact_number %></p>
      </div>
    <% end %>

    <div>
      <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider">住所</label>
      <p class="text-gray-900">
      <%= @parking_manager.address %>
      <span class="text-sm"><%= @parking_manager.building %></span>
      </p>
    </div>

    <div class="pt-4 border-t border-gray-100">
      <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider">登録日時</label>
      <p class="text-sm text-gray-600"><%= l @parking_manager.created_at, format: :long %></p>
    </div>
  </div>
</div>
