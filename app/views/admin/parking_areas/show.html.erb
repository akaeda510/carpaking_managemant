<div class="container mx-auto px-4 py-8">
  <%# パンくずリスト %>
  <nav class="flex mb-6 text-gray-500 text-sm font-medium" aria-label="Breadcrumb">
    <%= link_to '駐車場一覧', admin_parking_lots_path, class: "hover:text-blue-600 transition" %>
    <svg class="w-4 h-4 mx-2 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path d="M7.293 14.707a1 1 0 010-1.414L10.586 11l-3.293-3.293a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/></svg>
    <%= link_to @parking_lot.name, admin_parking_lot_path(@parking_lot), class: "hover:text-blue-600 transition" %>
    <span class="mx-2 text-gray-400">/</span>
    <span class="text-gray-800"><%= @parking_area.name %></span>
  </nav>

  <%# エリア情報カード %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-8">
    <div class="p-6 sm:flex sm:items-center sm:justify-between bg-gray-50 border-b border-gray-200">
      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= @parking_area.name %></h1>
        <div class="flex items-center gap-4 mt-1 text-sm text-gray-500">
          <span>所属：<%= @parking_lot.name %></span>
          </span>
        </div>
      </div>

      <%# 空き場所 / 登録場所 のカウント %>
      <div class="mt-4 sm:mt-0 flex gap-4">
        <div class="text-center px-4 py-2 bg-white rounded-lg border border-gray-200 shadow-sm">
          <span class="block text-[10px] text-gray-400 uppercase font-semibold">登録場所</span>
          <span class="text-xl font-bold text-gray-700"><%= @parking_spaces.count %></span>
        </div>
        <div class="text-center px-4 py-2 bg-white rounded-lg border border-gray-200 shadow-sm">
          <span class="block text-[10px] text-gray-400 uppercase font-semibold">空き場所</span>
          <span class="text-xl font-bold text-green-600"><%= @parking_spaces.available.count %></span>
        </div>
      </div>
    </div>

    <div class="p-6 bg-blue-50/30">
      <h3 class="text-xs font-bold text-blue-500 uppercase tracking-widest mb-2 flex items-center">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        エリア説明
      </h3>
      <p class="text-gray-700 leading-relaxed text-sm whitespace-pre-wrap">
        <%= @parking_area.description.presence || "説明文は設定されていません。" %>
      </p>
    </div>
  </div>

  <div class="mb-6">
    <h2 class="text-lg font-bold text-gray-800 flex items-center">
      <span class="w-1.5 h-6 bg-blue-600 rounded-full mr-3"></span>
      区画別ステータス確認
    </h2>
  </div>

  <% if @parking_spaces.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <% @parking_spaces.decorate.each do |space| %>
        <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm hover:border-blue-200 transition flex flex-col justify-between">
          <div>
            <div class="flex justify-between items-start mb-4">
              <span class="text-xl font-mono font-bold text-gray-900">No.<%= space.name %></span>
              <%= space.status_badge %>
            </div>

            <%# 契約者情報の追加 %>
            <div class="mb-4">
              <span class="text-[10px] font-semibold text-gray-400 uppercase block mb-1">現在の契約者</span>
              <% if space.current_contract %>
                <div class="flex items-center text-sm text-gray-800">
                  <i class="fa-solid fa-user-check mr-2 text-green-500"></i>
                  <%= space.current_contract.contractor.decorate.full_name %> 様
                </div>
              <% else %>
                <span class="text-sm text-gray-400 italic">未契約</span>
              <% if space.status == "reserved" %>
                <span class="text-xs text-amber-600 block mt-1">(予約あり)</span>
              <% end %>
              <% end %>
            </div>
          </div>

          <div class="pt-4 border-t border-gray-50 mt-auto">
            <%= link_to "#", 
                class: "flex items-center justify-center w-full px-3 py-2 bg-gray-50 hover:bg-blue-50 text-gray-600 hover:text-blue-600 text-xs font-semibold rounded transition border border-gray-100" do %>
              詳細を見る <i class="fa-solid fa-chevron-right ml-2 text-[10px]"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-50 border-2 border-dashed border-gray-200 rounded-xl p-12 text-center text-gray-400 text-sm">
      このエリアに登録されている区画データはありません。
    </div>
  <% end %>
</div>
