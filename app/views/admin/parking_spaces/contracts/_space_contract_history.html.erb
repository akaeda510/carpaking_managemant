<section class="mt-10 pt-8 border-t border-gray-100">
  <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
    <i class="fa-solid fa-clock-rotate-left mr-2 text-gray-400"></i> 区画の利用履歴
  </h3>
  
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">契約者</th>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">利用期間</th>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">状態</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% if contract_histories.any? %>
          <% contract_histories.each do |contract| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">
                  <%= contract.contractor.decorate.full_name %> 様
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                <%= contract.start_date.strftime("%Y/%m/%d") %> 〜 
                <%= contract.end_date&.strftime("%Y/%m/%d") || "（利用中）" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if contract.end_date.nil? || contract.end_date > Date.today %>
                  <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-green-100 text-green-700">有効</span>
                <% else %>
                  <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold bg-gray-100 text-gray-500">終了</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="3" class="px-6 py-10 text-center text-sm text-gray-400 italic">
              過去の利用履歴はありません。
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
