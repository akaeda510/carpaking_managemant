<div class="max-w-[95rem] mx-auto p-12">
  <div class="mb-8">
    <%= link_to admin_parking_lots_path, class: "inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-800 transition mb-4" do %>
      <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      駐車場一覧に戻る
    <% end %>
    
    <div class="flex items-end justify-between border-b border-gray-100 pb-8">
      <div>
        <h1 class="text-4xl font-extrabold tracking-tight text-gray-950"><%= @parking_lot.name %></h1>
        <div class="mt-3 flex items-center gap-4 text-gray-600 text-lg">
          <%= "#{@parking_lot.address}" %>
        </div>
      </div>
      
      <div class="flex gap-6">
        <div class="bg-white border border-gray-100 rounded-2xl px-8 py-5 shadow-sm min-w-[240px]">
          <div class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">駐車場全体の区画充足率</div>
          
          <% all_spaces_count = @parking_lot.parking_areas.joins(:parking_spaces).count %>
          
          <div class="flex items-baseline gap-2 mb-3">
            <span class="text-4xl font-black text-indigo-600"><%= all_spaces_count %></span>
            <span class="text-gray-300 text-2xl font-light">/</span>
            <span class="text-2xl font-bold text-gray-900"><%= @parking_lot.total_spaces %></span>
            <span class="text-sm text-gray-500 font-medium ml-1">区画</span>
          </div>
          
          <div class="w-full bg-gray-100 rounded-full h-3 overflow-hidden">
            <% total_percentage = (all_spaces_count.to_f / @parking_lot.total_spaces.to_f * 100).clamp(0, 100) %>
            <div class="bg-indigo-600 h-full rounded-full transition-all duration-500" style="width: <%= total_percentage %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-12">
    <div class="flex items-center mb-8">
      <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-3">
        <div class="p-2 bg-indigo-50 rounded-lg">
          <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
        </div>
        構成エリア
      </h2>
      <span class="ml-4 px-3 py-1 bg-gray-100 text-gray-600 text-sm font-bold rounded-full">
        全 <%= @parking_areas.count %> エリア
      </span>
    </div>

    <% if @parking_areas.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @parking_areas.each do |area| %>
          <div class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-indigo-100 transition-all duration-300 p-8">
            <div class="flex justify-between items-start mb-6">
              <div>
                <h3 class="text-xl font-bold text-gray-900 group-hover:text-indigo-600 transition-colors"><%= area.name %></h3>
                <p class="text-sm text-gray-400 mt-1 italic">Area ID: #<%= area.id %></p>
              </div>
            </div>
            
            <div class="bg-gray-50 rounded-xl p-5 border border-gray-50">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-gray-500">現在の登録区画数</span>
                <div class="flex items-baseline gap-1">
                  <span class="text-2xl font-black text-gray-900"><%= area.parking_spaces.count %></span>
                  <span class="text-xs text-gray-400 font-bold uppercase">区画数</span>
                </div>
              </div>
            </div>

            <div class="mt-8 pt-6 border-t border-gray-50">
              <%= link_to '#', class: "w-full flex items-center justify-center gap-2 py-3 px-4 rounded-xl bg-gray-50 text-sm font-bold text-gray-600 hover:bg-indigo-600 hover:text-white transition-all duration-300" do %>
                区画詳細・管理
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-24 bg-white rounded-3xl border-2 border-dashed border-gray-100">
        <p class="text-gray-400 font-medium text-lg">エリアデータがまだ登録されていません</p>
      </div>
    <% end %>
  </div>
</div>
