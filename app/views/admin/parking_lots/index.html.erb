<div class="p-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800">駐車場一覧</h1>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden border border-gray-200">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">駐車場名</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">所在地</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">構成エリア</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">区画最大数</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">アクション</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @parking_lots.each do |lot| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= lot.name %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= "#{lot.address}" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-center text-sm">
              <span class="px-2.5 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                <%= lot.parking_areas.count %> エリア
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-bold text-gray-700">
              <%= lot.total_spaces %> <span class="text-xs font-normal text-gray-400">区画</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
              <%= link_to '詳細', admin_parking_lot_path(lot), class: "text-indigo-600 hover:text-indigo-900" %>
              <span class="text-gray-300">|</span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  
  <% if @parking_lots.empty? %>
    <div class="text-center py-12 bg-white mt-4 rounded-lg border-2 border-dashed border-gray-200">
      <p class="text-gray-500">登録されている駐車場はありません。</p>
    </div>
  <% end %>
</div>
