<li class="p-4 sm:px-6 hover:bg-indigo-50/30 transition duration-150 ease-in-out">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-start lg:items-center">

    <div class="lg:col-span-4 min-w-0">
      <div class="flex items-center">
        <div class="overflow-hidden">
          <div class="text-sm font-bold text-gray-900 flex items-center">
            <span class="lg:hidden text-[10px] bg-gray-100 px-1.5 py-0.5 rounded mr-2 text-gray-500 font-normal">契約者</span>
            <%= contractor.full_name %>
          </div>
          <div class="text-xs text-gray-500 mt-1 flex items-start">
            <i class="fa-solid fa-location-dot mr-1.5 mt-0.5 flex-shrink-0 text-indigo-400"></i>
            <span class="truncate" title="<%= contractor.address %>">
              <%= contractor.address %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <%# 2. 契約状況 %>
    <div class="lg:col-span-5">
      <div class="flex items-start lg:block">
        <span class="lg:hidden text-[10px] bg-gray-100 px-1.5 py-0.5 rounded mr-2 text-gray-500 mt-1">契約状況</span>
        <% if contractor.active_contract_parking_spaces.any? %>
          <div class="flex flex-wrap gap-1.5">
            <% contractor.active_contract_parking_spaces.each do |contract| %>
              <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[11px] font-medium bg-green-50 text-green-700 border border-green-100">
                <i class="fa-solid fa-car-side mr-1.5 text-green-500"></i>
                <span class="font-bold"><%= contract.parking_space.name %></span>
                <span class="mx-1.5 text-green-300">|</span>
                <span class="truncate max-w-[150px]"><%= contract.parking_space.parking_lot.name %></span>
              </span>
            <% end %>
          </div>
        <% else %>
          <span class="text-xs text-gray-400 italic">未契約</span>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-3 flex items-center justify-start lg:justify-end gap-2 mt-2 lg:mt-0 pt-3 lg:pt-0 border-t border-gray-50 lg:border-0">
      <%= action_button :show, contractor_path(contractor) %>
      <%= action_button :edit, edit_contractor_path(contractor) %>
      <%= action_button :delete, contractor_path(contractor), confirm: "#{contractor.full_name} 様のデータを削除しますか？" %>
    </div>
  </div>
</li>
