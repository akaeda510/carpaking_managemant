<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 flex items-center">
      <span class="mr-3">👤</span> 契約者一覧
    </h1>

    <%= link_to new_contractor_path, class: 'w-full sm:w-auto inline-flex justify-center items-center px-5 py-2.5 border border-transparent text-sm font-bold rounded-xl shadow-md text-white bg-indigo-600 hover:bg-indigo-700 transition-all active:scale-[0.98]' do %>
      <i class="fa-solid fa-user-plus mr-2"></i> 新しい契約者を登録
    <% end %>
  </div>

  <%= render 'shared/search_form', search_url: contractors_path, placeholder_text: "名前・電話・住所..." %>

  <div class="bg-white shadow-xl border border-gray-100 overflow-hidden rounded-2xl">
    <% if @contractors.any? %>
      <div class="hidden sm:block">
        <div class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest grid grid-cols-12 gap-4 border-b border-gray-100 bg-gray-50/50">
          <div class="col-span-4">氏名 / 住所</div>
          <div class="col-span-5">契約状況</div>
          <div class="col-span-3 text-right">操作</div>
        </div>
      </div>

      <ul role="list" class="divide-y divide-gray-100">
        <% @contractors.each do |contractor| %>
          <%= render 'contractor', contractor: contractor %>
        <% end %>
      </ul>
    <% else %>
      <div class="p-16 text-center">
        <% if params[:query].present? %>
          <div class="inline-flex items-center justify-center w-16 h-16 bg-gray-100 rounded-full mb-4">
            <i class="fa-solid fa-magnifying-glass text-2xl text-gray-400"></i>
          </div>
          <p class="text-gray-600 font-bold text-lg">「<%= params[:query] %>」に一致する契約者は見つかりません</p>
          <p class="text-gray-400 text-sm mt-2 mb-8">名前、電話番号、住所の一部などで再検索してください。</p>
          <%= link_to "検索をリセット", contractors_path, class: "text-indigo-600 font-bold hover:underline" %>
        <% else %>
          <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-50 rounded-full mb-4">
            <i class="fa-solid fa-users text-2xl text-indigo-200"></i>
          </div>
          <p class="text-lg text-gray-500 mb-6">まだ契約者が登録されていません。</p>
          <%= link_to new_contractor_path, class: 'inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-md hover:bg-indigo-700 transition' do %>
            最初の契約者を登録する
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
