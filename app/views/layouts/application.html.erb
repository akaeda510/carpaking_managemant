<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "駐車場管理システム" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Myapp">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
  </head>

  <body class="min-h-full flex flex-col bg-gray-100 m-0">
    <% if parking_manager_signed_in? &&
        !session[:needs_verification] &&
        controller_path != 'parking_managers/sessions' &&
        controller_path != 'parking_managers/devices' &&
        action_name != 'verified_success' &&
        action_name != 'wait_verification' %>

      <%# --- ログイン済み・承認済みメインレイアウト --- %>
      <%= render 'shared/header_signed_in' %>
      <div class="flex min-h-screen bg-sky-50 md:bg-transparent" id="wrapper">
        <%= render 'shared/sidebar_dashboard' %>

        <main class="flex-grow flex flex-col md:ml-64 mt-16 bg-sky-50 md:bg-background">
          <%= render 'shared/flash_messages' %>
          <div class="p-4 md:p-8 flex-grow">
            <div class="bg-white md:bg-transparent rounded-xl p-4 md:p-0 shadow-sm md:shadow-none">
              <%= yield %>
            </div>
          </div>

          <%# ログイン後のフッター（右寄せ） %>
          <footer class="mt-auto p-4">
            <%= render 'shared/footer_copyright', align: "right" %>
          </footer>
        </main>
      </div>

    <% else %>
      <%# --- ログイン前・承認待ち等レイアウト --- %>
      <%= render 'shared/header_public' %>
      <main class="flex-grow flex flex-col justify-start">
        <%= render 'shared/flash_messages' %>
        <div class="w-full">
          <%= yield %>
        </div>
      </main>

      <footer class="mt-auto">
        <% if !parking_manager_signed_in? %>
          <%# 完全な未ログイン状態 %>
          <%= render 'shared/footer_public' %>
        <% else %>
          <div class="w-full max-w-4xl px-4">
            <%= render 'shared/footer_copyright' %>
          </div>
        <% end %>
      </footer>
    <% end %>
  </body>
</html>
