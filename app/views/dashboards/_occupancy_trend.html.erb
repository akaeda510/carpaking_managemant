<div class="col-span-12 lg:col-span-8 bg-white p-8 rounded-xl shadow-sm border border-gray-100 min-h-[400px]">
  <div class="flex justify-between items-center mb-10">
    <div>
      <h3 class="font-headline text-xl font-bold text-gray-900">稼働率の推移</h3>
      <p class="text-sm text-gray-500">過去の履歴推移</p>
    </div>
  </div>

  <div data-controller="occupancy-chart">
    <%= column_chart @monthly_stats, 
      height: "300px",
      suffix: "%",
      thousands: ",",
      label: "月間稼働率",
      id: "occupancy-chart"
    %>
  </div>
</div>
