<%# app/views/dashboards/_occupancy_trend.html.erb %>
<div class="col-span-12 lg:col-span-8 bg-white p-8 rounded-xl shadow-sm border border-gray-100 min-h-[400px]">
  <div class="flex justify-between items-center mb-10">
    <div>
      <h3 class="font-headline text-xl font-bold text-gray-900">稼働率の推移(実装予定)</h3>
      <p class="text-sm text-gray-500">過去の履歴推移</p>
    </div>
  </div>
  
  <div class="relative h-64 flex items-end gap-4 px-2">
    <%# 今後Gemを導入した際は、ここをチャート描画タグに置き換える %>
<% 
    display_stats = @monthly_stats || { 
      "1月" => 60, "2月" => 65, "3月" => 75, "4月" => 80, "5月" => 82, "6月" => 85 
    } 
  %>

  <% display_stats.each do |month, rate| %>
    <div class="flex-1 flex flex-col items-center group">
      <div class="w-full bg-indigo-100 group-hover:bg-indigo-200 transition-all rounded-t-lg relative flex flex-col justify-end" style="height: <%= rate %>%">
        <div class="bg-indigo-600 h-1 w-full absolute top-0"></div>
        
        <%# 現在の月（最後）だけツールチップを出す演出 %>
        <% if month == display_stats.keys.last %>
          <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-gray-900 text-white text-[10px] font-bold py-1 px-2 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">
            現在: <%= rate %>%
          </div>
        <% end %>
      </div>
      <span class="mt-4 text-xs font-bold text-gray-400"><%= month %></span>
    </div>
  <% end %>
</div>
