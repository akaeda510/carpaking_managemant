<%= form_with model: @inquiry, url: contact_path, local: true, class: "space-y-6" do |f| %>

  <div>
    <%= f.label :name, class: "auth-label" %>
    <%= f.text_field :name, class: "auth-input", required: true %>
  </div>

  <div>
    <%= f.label :email, class: "auth-label" %>
    <%= f.email_field :email, class: "auth-input", required: true %>
  </div>

  <div>
    <%= f.label :subject, class: "auth-label" %>
    <%= f.text_field :subject, class: "auth-input", required: true %>
  </div>

  <div>
    <%= f.label :message, class: "auth-label" %>
    <%= f.text_area :message, rows: 5, class: "auth-textarea", required: true %>
  </div>

  <div>
    <%= f.submit "送信する", 
      data: { confirm: "この内容で送信してよろしいですか？", disable_with: "送信中..." },
      class: "auth-submit"%>
  </div>
<% end %>
