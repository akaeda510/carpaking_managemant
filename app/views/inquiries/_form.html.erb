<%= form_with model: @inquiry, url: contact_path, local: true, class: "space-y-6" do |f| %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "auth-input", required: true %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
    <%= f.email_field :email, class: "auth-input", required: true %>
  </div>

  <div>
    <%= f.label :subject, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :subject, class: "auth-input", required: true %>
  </div>

  <div>
    <%= f.label :message, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :message, rows: 5, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500", required: true %>
  </div>

  <div>
    <%= f.submit "送信する", 
      data: { confirm: "この内容で送信してよろしいですか？", disable_with: "送信中..." },
      class: "auth_submit"%>
  </div>
<% end %>
