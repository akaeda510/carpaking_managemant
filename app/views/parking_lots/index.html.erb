<%# app/views/parking_lots/index.html.erb %>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">
        <span class="mr-2">🅿️</span>駐車場一覧
      </h1>
      <p class="text-gray-500 font-medium mt-1">登録済みの駐車場を管理・編集できます</p>
    </div>
    
    <%= link_to new_parking_lot_path, class: 'inline-flex items-center px-5 py-2.5 border border-transparent text-sm font-bold rounded-xl shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 transition-all active:scale-[0.98]' do %>
      <span class="material-symbols-outlined mr-2 text-sm" style="font-variation-settings: 'wght' 700">add</span>
      新しい駐車場を登録
    <% end %>
  </div>
  
  <div class="bg-white shadow-sm border border-gray-100 rounded-2xl overflow-hidden">
    <% if @parking_lots.any? %>
      <%# ヘッダー（PCのみ） %>
      <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-4 bg-gray-50 border-b border-gray-100 text-xs font-bold text-gray-500 uppercase tracking-widest">
        <div class="col-span-3">駐車場名</div>
        <div class="col-span-5">住所</div>
        <div class="col-span-2">総スペース</div>
        <div class="col-span-2 text-right">アクション</div>
      </div>
      
      <ul role="list" class="divide-y divide-gray-100">
        <% @parking_lots.each do |parking_lot| %>
          <li class="px-6 py-5 hover:bg-gray-50 transition-colors">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
              
              <%# 駐車場名 %>
              <div class="col-span-1 md:col-span-3">
                <%= link_to parking_lot.name, parking_lot_parking_areas_path(parking_lot), class: "text-sm font-bold text-indigo-600 hover:text-indigo-800 transition-colors" %>
              </div>
              
              <%# 住所 %>
              <div class="col-span-1 md:col-span-5">
                <p class="text-sm text-gray-600 flex items-center gap-1">
                  <span class="material-symbols-outlined text-gray-400 text-base">location_on</span>
                  <%= parking_lot.address %>
                </p>
              </div>
              
              <%# 総スペース %>
              <div class="col-span-1 md:col-span-2">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-gray-100 text-gray-800">
                  <%= parking_lot.total_spaces %> 台
                </span>
              </div>

              <%# アクションボタン（右端に配置） %>
              <div class="col-span-1 md:col-span-2 flex justify-start md:justify-end gap-3 mt-4 md:mt-0">
                <%= action_button :edit, edit_parking_lot_path(parking_lot) %>
                <%= action_button :delete, parking_lot_path(parking_lot), 
                    confirm: "本当にこの駐車場を削除しますか？" %>
              </div>
            </div>
            
            <%# 説明文がある場合 %>
            <% if parking_lot.description.present? %>
              <div class="mt-3 text-xs text-gray-400 leading-relaxed bg-gray-50/50 p-2 rounded-lg border border-dashed border-gray-100">
                <span class="font-bold text-gray-500 mr-1">メモ:</span>
                <%= parking_lot.description %>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
      
    <% else %>
      <div class="p-16 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-50 text-gray-300 mb-4">
          <span class="material-symbols-outlined text-4xl">local_parking</span>
        </div>
        <p class="text-gray-900 font-extrabold text-xl mb-1">まだ駐車場が登録されていません</p>
        <p class="text-gray-500 mb-8">管理を開始するために、まずは駐車場を登録しましょう</p>
        <%= link_to '最初の駐車場を登録する', new_parking_lot_path, class: "text-indigo-600 font-bold hover:underline" %>
      </div>
    <% end %>
  </div>
</div>
