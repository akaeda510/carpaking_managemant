<li class="p-4 sm:px-6 hover:bg-indigo-50/30 transition-colors">
  <div class="flex flex-col sm:grid sm:grid-cols-8 gap-3 items-start sm:items-center">

    <%# 駐車番号 (col-1) %>
    <div class="flex sm:block sm:col-span-1 text-sm">
      <span class="sm:hidden w-24 flex-shrink-0 text-gray-400 font-medium">番号:</span>
      <span class="font-bold text-gray-900"><%= parking_space.name %></span>
    </div>

    <%# ステータス (col-1) %>
    <div class="flex sm:block sm:col-span-1 text-sm sm:text-center">
      <span class="sm:hidden w-24 flex-shrink-0 text-gray-400 font-medium">状態:</span>
      <%= parking_space.status_badge %>
    </div>

    <div class="flex sm:block sm:col-span-2 text-sm sm:text-center">
      <span class="sm:hidden w-24 flex-shrink-0 text-gray-400 font-medium">賃料:</span>
      <%= render 'price_display', parking_space: parking_space, parking_area: parking_area %>
    </div>

    <div class="flex sm:block sm:col-span-2 text-sm sm:text-center">
      <span class="sm:hidden w-24 flex-shrink-0 text-gray-400 font-medium">契約者:</span>
      <% active_contract = parking_space.contract_parking_spaces.find_by(end_date: ::ACTIVE_CONTRACT_END_DATE) %>
      <% if active_contract %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
          <%= active_contract.contractor.decorate.full_name %>
        </span>
      <% else %>
        <span class="text-gray-400 italic text-xs">未契約</span>
      <% end %>
    </div>

    <%# アクション (col-2) %>
    <div class="flex sm:block sm:col-span-2 text-sm sm:text-right w-full mt-2 sm:mt-0 border-t sm:border-none pt-2 sm:pt-0">
      <div class="flex space-x-4 sm:justify-end">
        <%= link_to '詳細', [parking_lot, parking_area, parking_space], class: "text-indigo-600 hover:text-indigo-900 font-bold" %>
        <%= link_to '削除', [parking_lot, parking_area, parking_space],
          data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' },
          class: "text-red-500 hover:text-red-700 font-bold" %>
      </div>
    </div>

  </div>
</li>
