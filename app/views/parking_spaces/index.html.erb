<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col lg:flex-row justify-between items-start mb-6 gap-6">
    <div class="min-w-0 flex-1">
      <nav class="flex mb-3" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center text-sm text-gray-500 gap-y-1">
          <li><%= link_to "駐車場一覧", parking_lots_path, class: "hover:text-indigo-600 transition-colors" %></li>
          <li class="flex items-center"><span class="mx-2 text-gray-300">/</span></li>
          <li><%= link_to "エリア一覧", parking_lot_parking_areas_path, class: "hover:text-indigo-600 transition-colors" %></li>
          <li class="flex items-center"><span class="mx-2 text-gray-300">/</span></li>
          <li class="font-bold text-gray-900 truncate max-w-[200px] sm:max-w-[400px]" title="<%= @parking_area.name %>">
            <%= @parking_area.name %>
          </li>
        </ol>
      </nav>

      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 leading-tight">
        <span class="text-indigo-600"><%= @parking_lot.name %></span>
        <span class="text-gray-400 font-light mx-2">:</span>
        <span class="break-words"><%= @parking_area.name %></span>
      </h1>
    </div>

    <div class="w-full lg:w-auto flex-shrink-0">
      <%= link_to [:new, @parking_lot, @parking_area, :parking_space],
        class: 'w-full lg:w-auto inline-flex justify-center items-center px-6 py-3 border border-transparent text-sm font-bold rounded-xl shadow-md text-white bg-indigo-600 hover:bg-indigo-700 transition-all hover:shadow-lg active:scale-[0.98]' do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
        区画を登録
      <% end %>
    </div>
  </div>

  <div class="bg-white shadow-xl border border-gray-100 overflow-hidden rounded-2xl">
    <% if @parking_spaces.any? %>
      <div class="hidden sm:block">
        <div class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest grid grid-cols-8 gap-2 border-b border-gray-100 bg-gray-50/50">
          <div class="col-span-1">駐車番号</div>
          <div class="col-span-1 text-center">契約状態</div>
          <div class="col-span-2 text-center">月額賃料</div>
          <div class="col-span-2 text-center">契約者</div>
          <div class="col-span-2 text-right">アクション</div>
        </div>
      </div>

      <ul class="divide-y divide-gray-100">
        <%= render @parking_spaces, parking_lot: @parking_lot,  parking_area: @parking_area %>
      </ul>
    <% else %>

      <div class="p-8 text-center text-gray-500">
        <p class="text-lg mb-2">まだ駐車場スペースが登録されていません。</p>
        <%= link_to '最初のスペースを登録する', [:new, @parking_lot, @parking_area, :parking_space],
          class: 'text-indigo-600 hover:text-indigo-700 font-medium' %>
      </div>
    <% end %>
  </div>
</div>
