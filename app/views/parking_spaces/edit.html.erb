<div class="container mx-auto px-4 py-8 max-w-3xl">
  <nav class="flex text-sm text-gray-500 mb-4">
    <ol class="flex flex-wrap items-center text-sm text-    gray-500 gap-y-1">
    <li><%= link_to "区画一覧", [@parking_lot, @parking_area, :parking_spaces], class: "hover:text-indigo-600 transition-colors" %></li>
    <li class="flex items-center"><span class="mx-2 text-gray-300">/</span></li>
    <li><%= link_to "区画詳細", [@parking_lot, @parking_area, @parking_space], class: "hover:text-indigo-600 transition-colors" %></li>
    <li class="flex items-center"><span class="mx-2 text-gray-300">/</span></li>
    <li class="font-bold text-gray-900 truncate max-w-    [200px] sm:max-w-[400px]" title="<%= @parking_space.name %>">

      No.<%= @parking_space.name %></li>
    </ol>
  </nav>

  <div class="max-w-4xl w-full bg-white shadow-xl rounded-lg p-8" data-controller="parking-space-form">

    <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-8">
      駐車場スペース編集
    </h2>

    <%= render "form", parking_lot: @parking_lot, parking_space: @parking_space %>

    <div class="mt-6 text-center">
      <%= back_link_to "戻る", [@parking_lot, @parking_area, @parking_space], class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
    </div>
  </div>
</div>
