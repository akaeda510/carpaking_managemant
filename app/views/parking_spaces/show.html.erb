<div class="container mx-auto px-4 py-8 max-w-3xl">
  <nav class="flex text-sm text-gray-500 mb-4">
    <ol class="flex flex-wrap items-center text-sm text-    gray-500 gap-y-1">
    <li><%= link_to "区画一覧", parking_lot_parking_area_parking_spaces_path(@parking_lot, @parking_area), class: "hover:text-indigo-600 transition-colors" %></li>
    <li class="flex items-center"><span class="mx-2 text-gray-300">/</span></li>
    <li class="font-bold text-gray-900 truncate max-w-    [200px] sm:max-w-[400px]" title="<%= @parking_space.name %>">

      No.<%= @parking_space.name %></li>
    </ol>
  </nav>

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b pb-6 mb-8 gap-4">
    <h1 class="text-3xl font-bold text-gray-900">駐車区画: No. <%= @parking_space.name %></h1>
    <div class="flex space-x-3">
      <%= link_to '編集', edit_parking_lot_parking_area_parking_space_path(@parking_lot, @parking_area, @parking_space), 
          class: "px-5 py-2 bg-white border border-gray-300 rounded-lg font-bold text-gray-700 hover:bg-gray-50" %>
      <%= link_to '削除', [@parking_lot, @parking_area, @parking_space], 
          data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
          class: "px-5 py-2 bg-red-50 border border-red-200 rounded-lg font-bold text-red-600 hover:bg-red-100" %>
    </div>
  </div>

  <div class="space-y-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="p-6 bg-indigo-50 rounded-2xl border border-indigo-100">
        <p class="text-xs font-bold text-indigo-600 uppercase mb-2">月額賃料</p>
        <%= render 'price_display', parking_space: @parking_space, parking_area: @parking_area %>
      </div>
      <div class="p-6 bg-gray-50 rounded-2xl border border-gray-200">
        <p class="text-xs font-bold text-gray-500 uppercase mb-2">現在の状態</p>
        <div class="flex items-center space-x-2">
          <span class="text-xl font-bold text-gray-900"><%= @parking_space.status_i18n %></span>
        </div>
      </div>
    </div>

    <%# 4. 詳細スペック表 %>
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
        <h2 class="font-bold text-gray-800">区画スペック</h2>
      </div>
      <dl class="divide-y divide-gray-200">
        <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="auth-label">駐車タイプ</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2 font-bold"><%= @parking_area.category_i18n %></dd>
        </div>
        <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="auth-label">サイズ（幅 × 長さ）</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <span class="font-bold"><%= @parking_space.width %>m</span> × <span class="font-bold"><%= @parking_space.length %>m</span>
          </dd>
        </div>
        <% if @parking_area&.category == 'garage' && @parking_space.garage_detail.present? %>
          <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="auth-label text-indigo-600">高さ制限</dt>
            <dd class="mt-1 text-sm text-indigo-700 sm:mt-0 sm:col-span-2 font-bold"><%= @parking_space.garage_detail.height %>m</dd>
          </div>
        <% end %>
        <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="auth-label">オプション</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <% if @parking_space.parking_space_options.any? %>
              <div class="flex flex-wrap gap-2">
                <% @parking_space.parking_space_options.each do |opt| %>
                  <span class="bg-gray-100 text-gray-700 px-2 py-0.5 rounded text-xs border border-gray-200"><%= opt.name %></span>
                <% end %>
              </div>
            <% else %>
              <span class="text-gray-400">なし</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>

    <%# 5. 契約者情報 %>
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex justify-between">
        <h2 class="font-bold text-gray-800">契約情報</h2>
      </div>
      <div class="p-6">
        <% active_contract = @parking_space.contract_parking_spaces.find_by(end_date: ::ACTIVE_CONTRACT_END_DATE) %>
        <% if active_contract %>
          <div class="flex items-center space-x-4">
            <div class="flex-1">
              <p class="text-sm text-gray-500">契約者</p>
              <p class="text-lg font-bold text-indigo-600">
                <%= link_to active_contract.contractor.decorate.full_name, contractor_path(active_contract.contractor), class: "hover:underline" %>
              </p>
            </div>
            <div class="text-right">
              <p class="text-sm text-gray-500">契約開始日</p>
              <p class="font-bold"><%= active_contract.start_date.strftime("%Y/%m/%d") %></p>
            </div>
          </div>
        <% else %>
          <p class="text-center text-gray-500 py-4 italic">現在、この区画は空き状態です</p>
        <% end %>
      </div>
    </div>

    <%# 6. 説明文 %>
    <% if @parking_space.description.present? %>
      <div class="p-6 bg-white border border-gray-200 rounded-2xl">
        <h2 class="text-sm font-bold text-gray-500 uppercase mb-3">備考・説明</h2>
        <p class="text-gray-700 whitespace-pre-wrap text-sm leading-relaxed"><%= @parking_space.description %></p>
      </div>
    <% end %>
  </div>

  <div class="mt-10 text-center">
    <%= back_link_to '一覧に戻る', parking_lot_parking_area_parking_spaces_path, class: "text-indigo-600" %>
  </div>
</div>
