<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <nav class="flex mb-2" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm text-gray-500">
          <li><%= link_to "駐車場一覧", parking_lots_path, class: "hover:text-indigo-600" %></li>
          <li><span class="mx-2">/</span></li>
          <li class="font-bold text-gray-900"><%= @parking_lot.name %></li>
        </ol>
      </nav>
      <h1 class="text-3xl font-extrabold text-gray-900">
        🏢 エリア一覧
      </h1>
    </div>
    
    <%# 新規エリア作成ボタン %>
    <%= link_to '➕ 新しいエリアを登録', new_parking_lot_parking_area_path, 
          class: 'inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500' %>
  </div>
  
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <% if @parking_areas.any? %>
      
      <%# テーブルヘッダー - デザインを統一 %>
      <div class="hidden sm:block">
        <div class="px-4 py-3 sm:px-6 text-xs font-medium text-gray-500 uppercase tracking-wider grid grid-cols-6 gap-4 border-b border-gray-200">
          <div class="col-span-2">エリア名</div>
          <div class="col-span-1">カテゴリー</div>
          <div class="col-span-1">基本料金</div>
          <div class="col-span-1">区画数</div>
          <div class="text-right col-span-1">アクション</div>
        </div>
      </div>
      
      <ul role="list" class="divide-y divide-gray-200">
        <% @parking_areas.each do |area| %>
          <li class="p-4 sm:px-6 hover:bg-gray-50 transition duration-150 ease-in-out">
            
            <div class="grid grid-cols-6 gap-4 items-center">
              
              <div class="col-span-2 text-sm font-medium text-indigo-600">
                <%= link_to area.name, "#", class: "hover:underline" %>
              </div>
              
              <div class="col-span-1 text-sm text-gray-900">
                <%# i18nが未設定の場合は area.category.capitalize など %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                  <%= area.category_i18n %>
                </span>
              </div>
              
              <div class="col-span-1 text-sm text-gray-900 font-mono">
                <%= number_to_currency(area.default_price, unit: "¥", precision: 0) %>
              </div>

              <div class="col-span-1 text-sm text-gray-900">
                <%= area.parking_spaces.count %> 区画
              </div>

              <div class="col-span-1 text-right flex justify-end space-x-3">
                <%= link_to '編集', edit_parking_lot_parking_area_path(@parking_lot, area), class: 'text-yellow-600 hover:text-yellow-900 text-sm' %>
                
                <%= link_to '削除', "#", 
                      data: { turbo_method: :delete,
                              turbo_confirm: "エリアを削除すると、所属する全ての区画も削除されます。本当によろしいですか？"},
                              class: 'text-red-600 hover:text-red-900 text-sm' %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
      
    <% else %>
      <div class="p-8 text-center text-gray-500">
        <p class="text-lg mb-2">まだエリアが登録されていません。</p>
        <p>「ガレージ」「砂利エリア」など、駐車場内の区分を作成しましょう。</p>
      </div>
    <% end %>
  </div>
</div>
<%= turbo_frame_tag "model" %>
